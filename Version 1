Version 1  The Player Update  Sprites are saved privately

init = function()
  player = object end
  player.x = 0
  player.y = 0
  player.speed = 2
  
end

update = function()
  if keyboard.UP then
    player.y += player.speed
  end
  if keyboard.DOWN then
    player.y -= player.speed 
  end
  if keyboard.RIGHT then
    player.x += player.speed
  end
  if keyboard.LEFT then
    player.x -= player.speed
  end
  
end

draw = function()
  screen.clear("rgb(87,197,197)")
  screen.drawSprite( "player", player.x, player.y, 50, 50 )
end
